{
  "version": 2,
  "builds": [
    {
      "src": "frontend/**",
      "use": "@vercel/static"
    },
    {
      "src": "docs/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/capacity.json",
      "dest": "/docs/capacity.json"
    },
    {
      "src": "/norway.geojson",
      "dest": "/docs/norway.geojson"
    },
    {
      "src": "/(.*)",
      "dest": "/frontend/$1"
    }
  ]
}
